skinparam actorBackgroundColor #D6E8FF
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam packageBackgroundColor #F5F5F5
skinparam packageBorderColor #AAAAAA
skinparam arrowColor #555555
skinparam linetype ortho
skinparam nodesep 30
skinparam ranksep 40

title **USE CASE DIAGRAM - TVU Fund Management System**

left to right direction

' Actors cong khai
actor "Khách truy cập" as KH
actor "Sinh viên" as SV
actor "Nhà tài trợ" as NTT
KH -[hidden]down- SV
SV -[hidden]down- NTT

rectangle "Hệ thống TVU Fund Management" {

  package "Công khai & tra cứu" as PKG_PUBLIC {
    (Xem landing & thống kê công khai) as UC01
    (Xem danh sách quỹ) as UC02
    (Xem chi tiết quỹ) as UC03
    (Xem bảng vàng / tri ân nhà tài trợ) as UC04
    (Xem sinh viên nổi bật) as UC05
    (Xem tin mới / tin nổi bật) as UC06
    (Xem tất cả cảm nhận sinh viên) as UC07
    (Gửi cảm nhận chờ kiểm duyệt) as UC08
    (Tra cứu trạng thái bằng mã theo dõi) as UC09
    (Xem trang đối tác nhà tài trợ) as UC10
  }

  package "Xác thực & hồ sơ" as PKG_AUTH {
    (Đăng ký tài khoản) as UC11
    (Đăng nhập / Google OAuth) as UC12
    (Đăng xuất) as UC13
    (Đổi mật khẩu) as UC14
    (Quản lý hồ sơ cá nhân) as UC15
    (Quản lý tài khoản ngân hàng cá nhân) as UC16
  }

  package "Hỗ trợ sinh viên" as PKG_APPLICATION {
    (Nộp đơn xin hỗ trợ) as UC17
    (Nộp đơn khách vãng lai) as UC18
    (Xác minh OTP email) as UC19
    (Tải minh chứng / tài liệu đính kèm) as UC20
    (AI hỗ trợ viết đơn) as UC21
    (Theo dõi hồ sơ & lịch sử hỗ trợ) as UC22
  }

  package "Tài trợ" as PKG_DONATION {
    (Tạo khoản tài trợ khi đăng nhập) as UC23
    (Tạo khoản tài trợ công khai) as UC24
    (Tạo khoản tài trợ khách vãng lai) as UC25
    (Tải chứng từ tài trợ) as UC26
    (Xem lịch sử & thống kê tài trợ) as UC27
    (Xem thông tin ngân hàng nhận tài trợ) as UC28
  }

  package "Quản lý quỹ & danh mục" as PKG_FUND {
    (Tạo / cập nhật quỹ) as UC29
    (Cập nhật trạng thái & sức khỏe quỹ) as UC30
    (Quản lý loại quỹ) as UC31
    (Quản lý tài khoản ngân hàng quỹ) as UC32
    (Quản lý nhà tài trợ) as UC33
  }

  package "Nội dung công khai" as PKG_CONTENT {
    (Quản lý tin tức & sự kiện) as UC34
    (Phân loại Tin mới / Tin nổi bật) as UC35
    (Quản lý sinh viên nổi bật) as UC36
    (Quản lý cảm nhận sinh viên) as UC37
    (Duyệt / từ chối / chọn nổi bật cảm nhận) as UC38
  }

  package "Phê duyệt & giải ngân" as PKG_APPROVAL {
    (Xem danh sách hồ sơ hỗ trợ) as UC39
    (Phê duyệt hồ sơ cấp 1) as UC40
    (Phê duyệt hồ sơ cấp 2) as UC41
    (Phê duyệt cấp 3 & giải ngân) as UC42
    (Từ chối hồ sơ) as UC43
    (Xem lịch sử phê duyệt) as UC44
    (Xác nhận / duyệt / từ chối tài trợ) as UC45
    (Ghi nhận khoản tài trợ offline) as UC46
    (Tạo giao dịch & cập nhật số dư quỹ) as UC47
  }

  package "Tài chính & báo cáo" as PKG_FINANCE {
    (Xem lịch sử giao dịch) as UC48
    (Đối soát chứng từ) as UC49
    (Xem dashboard thống kê) as UC50
    (Xuất báo cáo / Excel) as UC51
  }

  package "Quản trị hệ thống" as PKG_ADMIN {
    (Quản lý người dùng) as UC52
    (Quản lý vai trò) as UC53
    (Ma trận phân quyền trang) as UC54
    (Cài đặt hệ thống, footer, liên hệ, ngân hàng) as UC55
    (Xem / xuất nhật ký hệ thống) as UC56
    (Ghi nhật ký tác động dữ liệu) as UC57
  }

